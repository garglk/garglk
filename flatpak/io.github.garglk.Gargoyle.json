{
    "app-id": "io.github.garglk.Gargoyle",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "gargoyle",
    "finish-args": [
        "--socket=fallback-x11",
        "--socket=wayland",
        "--share=ipc",
        "--device=dri",
        "--socket=pulseaudio",
        "--filesystem=home:rw"
    ],
    "build-options": {
        "no-debuginfo": true
    },
    "modules": [
        {
            "name": "gargoyle",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_INSTALL_PREFIX=/app",
                "-DWITH_BUNDLED_FMT=OFF",
                "-DWITH_TTS=OFF"
            ],
            "post-install": [
                "mkdir -p /app/share/icons/hicolor/32x32/apps /app/share/icons/hicolor/128x128/apps",
                "mv /app/share/icons/io.github.garglk.Gargoyle.png /app/share/icons/hicolor/32x32/apps/",
                "cp /app/share/icons/hicolor/32x32/apps/io.github.garglk.Gargoyle.png /app/share/icons/hicolor/128x128/apps/",
                "mv /app/share/applications/io.github.garglk.GargoyleEditConfig.desktop /app/share/applications/io.github.garglk.Gargoyle.EditConfig.desktop"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/garglk/garglk/releases/download/2026.1.1/gargoyle-2026.1.1.tar.gz",
                    "sha256": "15f41293383de97f40eb24b40412be7eb9e452a28287367089664483ef3502f3"
                }
            ]
        }
    ]
}
